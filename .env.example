# MongoDB Atlas usado pelo Prisma.
# IMPORTANTE: coloque o nome do banco depois do host, antes da interrogação.
# Certo: mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/edificio118?retryWrites=true&w=majority
# Errado: mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/?appName=cluster
DATABASE_URL="mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/edificio118?retryWrites=true&w=majority&authSource=admin&tls=true"

# Mantido para compatibilidade de deploy. No MongoDB + Prisma, pode repetir o DATABASE_URL.
DIRECT_URL="mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/edificio118?retryWrites=true&w=majority&authSource=admin&tls=true"

# Senha simples do painel administrativo. Nunca exponha no client.
ADMIN_SENHA="troque-essa-senha"

# Segredo opcional para assinar o cookie HTTP-only do admin.
# Se não preencher, o sistema usa ADMIN_SENHA como base.
ADMIN_SESSION_SECRET="troque-por-um-segredo-maior-em-producao"

# Vercel Blob Storage para uploads de imagens em produção.
# No Vercel, crie um Storage Blob público e adicione este token no ENV.
# Sem token, uploads locais continuam indo para public/uploads durante desenvolvimento.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxx"

# WhatsApp da loja. Use DDI + DDD + número, sem espaços, parênteses ou traços.
WHATSAPP_NUMBER="5522999999999"

# Informações públicas do site.
NUXT_PUBLIC_SITE_NAME="Edificio 118"
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
NUXT_PUBLIC_PLACEHOLDER_IMAGE="/images/editorial/corre-com-nos.webp"
