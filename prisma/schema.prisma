generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Material {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Drop {
  id                      String    @id @default(auto()) @map("_id") @db.ObjectId
  title                   String
  slug                    String    @unique
  description             String
  shortLabel              String?
  images                  String[]
  isActive                Boolean   @default(true)
  isFeatured              Boolean   @default(false)
  isDefault               Boolean   @default(false)
  displayOrder            Int       @default(0)
  buttonLabel             String?
  secondaryButtonLabel    String?
  storySectionTitle       String?
  storySectionDescription String?
  highlightColor          String?   @default("#D6FF2F")
  layoutModel             String    @default("editorial-building")
  dropPhrases             String[]  @default([])
  products                Product[]
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model Product {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  slug              String       @unique
  shortDescription  String
  description       String
  story             String?
  materialNote      String?
  salePrice         Float
  promotionalPrice  Float?
  costPrice         Float?
  profit            Float?
  profitMargin      Float?
  stock             Int          @default(0)
  sizes             String[]
  colors            String[]
  images            String[]
  mainImage         String?
  isActive          Boolean      @default(true)
  isPublished       Boolean      @default(false)
  isFeatured        Boolean      @default(false)
  allowWhatsapp     Boolean      @default(true)
  displayOrder      Int          @default(0)
  internalNotes     String?
  categoryId        String?      @db.ObjectId
  materialId        String?      @db.ObjectId
  dropId            String?      @db.ObjectId
  category          Category?    @relation(fields: [categoryId], references: [id])
  material          Material?    @relation(fields: [materialId], references: [id])
  drop              Drop?        @relation(fields: [dropId], references: [id])
  manualSales       ManualSale[]
  expenses          Expense[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model ManualSale {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  productId            String   @db.ObjectId
  product              Product  @relation(fields: [productId], references: [id])
  productNameSnapshot  String
  categoryNameSnapshot String?
  soldAt               DateTime
  quantity             Int
  unitPrice            Float
  unitCost             Float    @default(0)
  discount             Float    @default(0)
  totalRevenue         Float
  totalCost            Float
  estimatedProfit      Float
  channel              String   @default("WhatsApp")
  notes                String?
  shouldDecreaseStock  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  category    String
  amount      Float
  spentAt     DateTime
  description String?
  expenseType String   @default("Outro")
  productId   String?  @db.ObjectId
  product     Product? @relation(fields: [productId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GeneratedReport {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  type        String
  groupBy     String
  metrics     String[]
  dateFrom    DateTime
  dateTo      DateTime
  rowsJson    String
  totalsJson  String
  csv         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReportPreset {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  type      String
  groupBy   String
  metrics   String[]
  dateFrom  DateTime?
  dateTo    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


model SavedColor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
